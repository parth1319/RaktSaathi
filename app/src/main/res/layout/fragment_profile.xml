<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tool="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tool:context="com.parth.raktsaathi.Fragments.ProfileFragment"
    android:orientation="vertical"
    android:background="@drawable/profile_baground"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <androidx.cardview.widget.CardView
        android:layout_width="380dp"
        android:layout_height="200dp"
        android:layout_marginTop="38dp"
        app:cardBackgroundColor="#D0C9C9"
        app:cardCornerRadius="18dp"
        app:cardElevation="8dp"
        app:cardUseCompatPadding="true"
        android:layout_gravity="center_horizontal"
       >

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_margin="8sp"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/ivMyProfileEditProfile"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_gravity="right"
                android:src="@drawable/rs_myprofile_edit"
                app:tint="#000000"
              />

            <de.hdodenhof.circleimageview.CircleImageView
                android:id="@+id/ivMyProfileSelectedProfile"
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:layout_gravity="center"
                android:src="@drawable/rs_profilelogo"
                app:civ_border_width="2dp"
                app:civ_border_color="@color/rs_buttons_colour"/>

            <Button
                android:id="@+id/btnMyProfilSelectProfilePhoto"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8sp"
                android:backgroundTint="@color/rs_heading_color"
                android:drawableLeft="@drawable/rs_myprofile_gallary"
                android:drawableTint="@color/white"
                android:fontFamily="@font/poppins_bold"
                android:shadowColor="@color/light_grey"
                android:text="Select Profile Photo"
                android:textColor="@color/black"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvMyProfileUserName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_margin="8sp"
                android:layout_marginLeft="16sp"
                android:layout_marginTop="8sp"
                android:background="@drawable/edit_text_bg"
                android:layout_marginRight="16sp"
                android:fontFamily="@font/poppins_bold"
                android:text="User Name"
                android:textColor="@color/black"
                android:textSize="16sp"
                android:textStyle="bold" />


            <TextView
                android:id="@+id/tvMyProfileMobileNo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_margin="8sp"
                android:layout_marginLeft="16sp"
                android:background="@drawable/edit_text_bg"
                android:layout_marginTop="8sp"
                android:layout_marginRight="16sp"
                android:fontFamily="@font/poppins_bold"
                android:text="Mobile Number"
                android:textColor="@color/black"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvMyProfileEmailid"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_margin="8sp"
                android:layout_marginLeft="16sp"
                android:layout_marginTop="8sp"
                android:layout_marginRight="16sp"
                android:fontFamily="@font/poppins_bold"
                android:text="Email Id"
                android:textColor="@color/black"
                android:textSize="16sp"
                android:textStyle="bold"
                android:background="@drawable/edit_text_bg"
                />

            <TextView
                android:id="@+id/tvMyProfilebBloodGroup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_margin="8sp"
                android:layout_marginLeft="16sp"
                android:layout_marginTop="8sp"
                android:layout_marginRight="16sp"
                android:fontFamily="@font/poppins_bold"
                android:text="Blood Group"
                android:textColor="@color/black"
                android:textSize="16sp"
                android:textStyle="bold"
                android:background="@drawable/edit_text_bg"
                />

            <TextView
                android:id="@+id/tvMyProfileUserCity"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_margin="8sp"
                android:layout_marginLeft="16sp"
                android:layout_marginTop="8sp"
                android:layout_marginRight="16sp"
                android:fontFamily="@font/poppins_bold"
                android:text="City"
                android:textColor="@color/black"
                android:textSize="16sp"
                android:textStyle="bold"
                android:background="@drawable/edit_text_bg"
                />

            <Button
                android:id="@+id/btnMyProfileDeleteAccount"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16sp"
                android:backgroundTint="@color/rs_heading_color"
                android:fontFamily="@font/poppins_bold"
                android:shadowColor="@color/light_grey"
                android:text="Delete Account"
                android:textColor="@color/black"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

</ScrollView>