<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/scrollMain"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F6F8">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="260dp"
            android:background="@drawable/red_gradient"
            android:gravity="bottom|center_horizontal"
            android:paddingBottom="20dp"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/imgProfile"
                android:layout_width="90dp"
                android:layout_height="90dp"
                android:src="@drawable/rs_profilelogo"/>

            <TextView
                android:layout_height="match_parent"
                android:layout_width="wrap_content"
                android:id="@+id/tvName"
                android:text="User Name"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:textStyle="bold"
                android:layout_marginTop="6dp"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="420dp"
            android:background="@drawable/profile_card_bg"
            android:orientation="vertical"
            android:padding="18dp"
            android:elevation="12dp"
            android:layout_marginTop="-40dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp">

            <TextView
                android:layout_height="match_parent"
                android:layout_width="wrap_content"
                android:id="@+id/tvMobile" android:text="📞 Mobile"/>
            <TextView
                android:layout_height="match_parent"
                android:layout_width="wrap_content"
                android:id="@+id/tvEmail"
                android:text="📧 Email"
                android:layout_marginTop="6dp"/>
            <TextView
                android:layout_height="match_parent"
                android:layout_width="wrap_content"
                android:id="@+id/tvBlood"
                android:text="🩸 Blood Group"
                android:layout_marginTop="6dp"/>
            <TextView
                android:layout_height="match_parent"
                android:layout_width="wrap_content"
                android:id="@+id/tvCity" android:text="📍 City" android:layout_marginTop="6dp"/>

            <LinearLayout
                android:id="@+id/btnSettingsToggle"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="10dp">

                <TextView
                    android:layout_height="match_parent"
                    android:layout_width="wrap_content"
                    android:layout_weight="1"
                    android:text="⚙️ Settings"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_height="match_parent"
                    android:layout_width="wrap_content"
                    android:id="@+id/arrowSettings"
                    android:text="▼"/>
            </LinearLayout>

            <LinearLayout
                android:layout_height="match_parent"
                android:layout_width="wrap_content"
                android:id="@+id/settingsContent"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_height="match_parent"
                    android:layout_width="wrap_content"
                    android:id="@+id/btnEditProfile"
                    android:text="✏️ Edit Profile"
                    android:padding="10dp"/>

                <TextView
                    android:layout_height="match_parent"
                    android:layout_width="wrap_content"
                    android:id="@+id/btnChangePass"
                    android:text="🔒 Change Password"
                    android:padding="10dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_height="match_parent"
                        android:layout_width="wrap_content"
                        android:layout_weight="1"
                        android:text="🌙 Dark Mode"/>

                    <Switch
                        android:layout_height="match_parent"
                        android:layout_width="wrap_content"
                        android:id="@+id/switchDark"/>
                </LinearLayout>

            </LinearLayout>

            <LinearLayout
                android:id="@+id/btnAboutToggle"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_height="match_parent"
                    android:layout_width="wrap_content"
                    android:layout_weight="1"
                    android:text="ℹ️ About Us"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_height="match_parent"
                    android:layout_width="wrap_content"
                    android:id="@+id/arrowAbout"
                    android:text="▼"/>
            </LinearLayout>

            <TextView
                android:layout_height="match_parent"
                android:layout_width="wrap_content"
                android:id="@+id/aboutContent"
                android:visibility="gone"
                android:text="Raktsaathi connects donors and patients instantly. This app helps save lives during emergencies by reducing delay in finding blood. Regular donation helps maintain good health and builds a strong community."
                android:layout_marginTop="10dp"/>

            <TextView
                android:layout_height="match_parent"
                android:layout_width="wrap_content"
                android:id="@+id/btnLogout"
                android:text="🚪 Logout"
                android:textColor="#D32F2F"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginTop="20dp"
                android:padding="12dp"/>

        </LinearLayout>

    </LinearLayout>
</ScrollView>