<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F2F2F2"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="18dp">

        <!-- TITLE -->
        <TextView
            android:layout_height="match_parent"
            android:layout_width="wrap_content"
            android:text="🩺 Health Tips and Awareness"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="#B71C1C"
            android:layout_marginBottom="10dp"/>

        <!-- 🩸 BLOOD DONATION -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="18dp"
            app:cardElevation="8dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:text="🩸 Blood Donation"
                    android:fontFamily="@font/poppins_semibold"
                    android:textColor="#111111"
                    android:textSize="20sp"
                    android:textStyle="bold" />


                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:fontFamily="@font/poppins_semibold"
                        android:text="🚭 Addiction Awareness"
                        android:textColor="#111111"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:layout_marginTop="6dp"
                        android:fontFamily="@font/poppins"
                        android:lineSpacingExtra="1dp"
                        android:text="Addiction to smoking, alcohol, and drugs harms both physical and mental health. It affects organs like lungs, liver, and brain, leading to serious diseases. Avoiding addiction is essential for a healthy life..."
                        android:textColor="#222222"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/tvLong2"
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:layout_marginTop="8dp"
                        android:text="Addiction is one of the biggest health risks today. It leads to diseases like lung cancer, liver cirrhosis, and mental disorders. Addiction affects decision-making ability and destroys relationships. Overcoming addiction requires strong willpower, family support, and sometimes medical help. Healthy habits such as exercise, meditation, and engaging in positive activities can help avoid addiction."
                        android:textColor="#222222"
                        android:textSize="15sp"
                        android:visibility="gone" />


                    <TextView
                        android:id="@+id/btnMore2"
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:text="See More"
                        android:textColor="#1565C0" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tvLong1"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:layout_marginTop="8dp"
                    android:fontFamily="@font/poppins_black"
                    android:text="Blood donation plays a crucial role in saving lives. It helps accident victims, patients undergoing surgery, and people suffering from serious diseases like cancer. When a person donates blood, the body generates new blood cells, improving circulation and overall health. It also reduces excess iron levels which lowers the risk of heart disease. A healthy person can donate blood every 3 months. Before donating, proper hydration and nutrition are important. After donation, rest and a healthy diet help the body recover faster."
                    android:textColor="#222222"
                    android:textSize="15sp"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/btnMore1"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:text="See More"
                    android:textColor="#1565C0" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- 🚭 ADDICTION -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:cardCornerRadius="18dp"
            app:cardElevation="8dp">

        </androidx.cardview.widget.CardView>

        <!-- ❤️ HEART -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:cardCornerRadius="18dp"
            app:cardElevation="8dp">

            <LinearLayout
                android:layout_height="match_parent"
                android:layout_width="wrap_content"
                android:padding="18dp"
                android:orientation="vertical">

                <TextView
                    android:layout_height="match_parent"
                    android:layout_width="wrap_content"
                    android:text="❤️ Heart Health"
                    android:fontFamily="@font/poppins_semibold"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#111111"/><![CDATA[
                />

                />

                ]]>

                <TextView
                    android:layout_height="match_parent"
                    android:layout_width="wrap_content"
                    android:id="@+id/tvLong3"
                    android:visibility="gone"
                    android:text="Heart diseases are increasing rapidly due to unhealthy lifestyles. Regular physical activity improves blood circulation. A diet rich in fruits and vegetables helps reduce cholesterol levels. Avoid smoking and alcohol. Managing stress through meditation and getting proper sleep helps maintain heart health."
                    android:textSize="15sp"
                    android:layout_marginTop="8dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:layout_marginTop="6dp"
                    android:text="Heart health is essential for a long life. Exercise, healthy diet, and stress control are key factors. Avoid junk food and smoking to keep your heart strong..."
                    android:textColor="#222222"
                    android:textSize="13dp"
                    android:fontFamily="@font/poppins"
                    android:lineSpacingExtra="1dp"
                    />

                <TextView
                    android:layout_height="match_parent"
                    android:layout_width="wrap_content"
                    android:id="@+id/btnMore3"
                    android:text="See More"
                    android:textColor="#1565C0"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- 🧠 MENTAL HEALTH -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:cardCornerRadius="18dp"
            app:cardElevation="8dp">

            <LinearLayout
                android:layout_height="match_parent"
                android:layout_width="wrap_content"
                android:padding="18dp"
                android:orientation="vertical">

                <TextView
                    android:layout_height="match_parent"
                    android:layout_width="wrap_content"
                    android:text="🧠 Mental Health"
                    android:textSize="18sp"
                    android:fontFamily="@font/poppins_semibold"
                    android:textStyle="bold"
                    android:textColor="#111111"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:layout_marginTop="6dp"
                    android:fontFamily="@font/poppins"
                    android:lineSpacingExtra="1dp"
                    android:text="Blood donation is a life-saving act that helps people during emergencies, surgeries, and medical conditions. It improves blood circulation and promotes better health. Donating blood regularly helps maintain iron balance and reduces heart risks..."
                    android:textColor="#222222"
                    android:textSize="13sp" />

                <TextView
                    android:layout_height="match_parent"
                    android:layout_width="wrap_content"
                    android:text="Mental health affects how we think and feel. Managing stress and staying positive is important. Talking to loved ones and practicing meditation helps..."
                    android:textSize="15sp"
                    android:lineSpacingExtra="1dp"
                    android:layout_marginTop="6dp"
                    android:textColor="#111111"/>

                <TextView
                    android:layout_height="match_parent"
                    android:layout_width="wrap_content"
                    android:id="@+id/tvLong4"
                    android:visibility="gone"
                    android:lineSpacingExtra="1dp"
                    android:fontFamily="@font/poppins"
                    android:text="Mental health includes emotional and psychological well-being. Poor mental health can lead to anxiety and depression. Regular exercise, proper sleep, and social interaction help improve mental stability. Meditation and relaxation techniques are very effective."
                    android:textSize="15sp"
                    android:layout_marginTop="8dp"
                    android:textColor="#111111"/>

                <TextView
                    android:layout_height="match_parent"
                    android:layout_width="wrap_content"
                    android:id="@+id/btnMore4"
                    android:text="See More"
                    android:textColor="#1565C0"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>