<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_marginTop="12dp"
    android:layout_marginStart="2dp"
    android:layout_marginEnd="2dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="6dp"
    android:backgroundTint="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <!-- 🩸 CAMP NAME -->
        <TextView
            android:id="@+id/tvCampName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="City Blood Camp"
            android:textStyle="bold"
            android:textSize="17sp"
            android:textColor="@color/black"/>

        <!-- 📅 DATE -->
        <TextView
            android:id="@+id/tvCampDate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Date: 20 April"
            android:textSize="15sp"
            android:textColor="@color/black"
            android:layout_marginTop="4dp"/>

        <!-- 📍 LOCATION -->
        <TextView
            android:id="@+id/tvCampLocation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📍 Akola City Ground"
            android:textSize="15sp"
            android:textColor="@color/black"
            android:layout_marginTop="4dp"/>

        <!-- BUTTON -->
        <Button
            android:id="@+id/btnCampRegister"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:text="Register"
            android:textStyle="bold"
            android:layout_marginTop="10dp"
            android:backgroundTint="@color/rs_buttons_colour"
            android:textColor="@android:color/white"/>

    </LinearLayout>

</androidx.cardview.widget.CardView>