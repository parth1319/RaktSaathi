<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/rs_bg_color">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="8dp">

        <TextView
            android:id="@+id/tvHomeUserName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:text="Hi, User"
            android:textColor="@color/rs_heading_color"
            android:textSize="28sp"
            android:textStyle="bold"
            android:layout_marginTop="30dp"/>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="4dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_location" />

            <TextView
                android:id="@+id/txtCity"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/poppins"
                android:text="....."
                android:textColor="@color/black"
                android:textSize="14sp" />
                   </LinearLayout>

        <!-- Main Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginTop="15dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btndonatebloodbtn"
                android:text="Donate Blood"
                android:textColor="#FFFFFF"
                android:backgroundTint="@color/rs_buttons_colour"
                android:layout_marginTop="20dp"
                android:layout_width="0sp"
                android:layout_height="50sp"
                android:layout_weight="1"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColorHint="@color/rs_heading_color"
                android:layout_marginEnd="8dp"/>

            <Button
                android:id="@+id/btnrequestbloodbtn"
                android:layout_width="0dp"
                android:layout_height="50sp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:layout_marginTop="20dp"
                android:backgroundTint="@color/rs_buttons_colour"
                android:text="Request Blood"
                android:textColor="#FFFFFF"
                android:textColorHint="@color/rs_heading_color"
                android:textSize="16sp"
                android:textStyle="bold" />


        </LinearLayout>

        <!-- Stats Cards -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="5dp"
                android:layout_weight="1"
                android:background="@drawable/bg_card_white"
                android:gravity="center"
                android:padding="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Requests\n12 Nearby"
                    android:textAlignment="center"
                    android:textColor="#424242"
                    android:textSize="12sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="5dp"
                android:layout_weight="1"
                android:background="@drawable/bg_card_white"
                android:gravity="center"
                android:padding="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Donors\n87 Available"
                    android:textAlignment="center"
                    android:textColor="#424242"
                    android:textSize="12sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="5dp"
                android:layout_weight="1"
                android:background="@drawable/bg_card_white"
                android:gravity="center"
                android:padding="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Blood Camps\nUpcoming 3"
                    android:textAlignment="center"
                    android:textColor="#424242"
                    android:textSize="12sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Search Bar -->
        <EditText
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="20dp"
            android:background="@drawable/bg_search_bar"
            android:drawableStart="@android:drawable/ic_menu_search"
            android:drawablePadding="10dp"
            android:hint="Search blood group, donor..."
            android:paddingHorizontal="15dp"
            android:textSize="14sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Nearby Donors"
            android:textColor="#B71C1C"
            android:textSize="16sp"
            android:textStyle="bold" />

     <androidx.recyclerview.widget.RecyclerView
         android:layout_width="match_parent"
         android:layout_height="wrap_content"
            android:layout_marginTop="17dp"
            android:id="@+id/donorRecycler"/>

    </LinearLayout>
</ScrollView>