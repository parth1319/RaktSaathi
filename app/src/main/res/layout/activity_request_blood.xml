<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/rs_bg_color">

    <LinearLayout
        android:orientation="vertical"
        android:padding="20dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="15dp"
            android:fontFamily="@font/poppins_bold"
            android:text="Request Blood"
            android:textColor="@color/rs_heading_color"
            android:textSize="24sp"
            android:textStyle="bold" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="18dp"
            app:cardElevation="8dp"
            android:layout_marginBottom="15dp"
            app:cardBackgroundColor="@color/rs_bg_color">

            <LinearLayout
                android:orientation="vertical"
                android:padding="16dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="5sp"
                    android:layout_marginBottom="15dp"
                    android:fontFamily="@font/poppins_bold"
                    android:text="Patient Details"
                    android:textColor="@color/rs_heading_color"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/etrequestbloodpatientname"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20sp"
                    android:drawableLeft="@drawable/rs_homeprofile_icon"
                    android:drawablePadding="10dp"
                    android:fontFamily="@font/poppins_semibold"
                    android:hint="Patient Name"
                    android:inputType="textPersonName"
                    android:textColor="@color/black"
                    android:textColorHint="@color/rs_qoute_color"
                    android:textSize="14dp"
                    tools:ignore="TextFields" />



                <Spinner
                    android:id="@+id/spinnerrequestbloodgroup"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:fontFamily="@font/poppins_semibold"
                    android:background="@android:drawable/editbox_background"
                    android:textColor="@color/black"
                    tools:ignore="InvalidId" />

                <Spinner
                    android:id="@+id/spinnerrequestbloodunit"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:fontFamily="@font/poppins_semibold"
                    android:background="@android:drawable/editbox_background"
                    android:textColor="@color/black"
                    tools:ignore="InvalidId" />

                <EditText
                    android:id="@+id/etrequestbloodhospitalname"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20sp"
                    android:drawableLeft="@drawable/rs_citylogo"
                    android:drawablePadding="10dp"
                    android:fontFamily="@font/poppins_semibold"
                    android:hint="Hospital Name"
                    android:inputType="textPersonName"
                    android:textColor="@color/black"
                    android:textColorHint="@color/rs_qoute_color"
                    android:textSize="14dp"
                    tools:ignore="TextFields" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>


        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="15dp"
            app:cardElevation="8dp"
            app:cardBackgroundColor="@color/rs_bg_color">

            <LinearLayout
                android:orientation="vertical"
                android:padding="16dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="5sp"
                    android:layout_marginBottom="15dp"
                    android:fontFamily="@font/poppins_bold"
                    android:text="Location"
                    android:textColor="@color/rs_heading_color"
                    android:textSize="18sp"
                    android:textStyle="bold" />


                <EditText
                    android:id="@+id/etrequestbloodcity"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/poppins_semibold"
                    android:hint="City"
                    android:textColor="@color/black"
                    android:textColorHint="@color/rs_qoute_color"
                    android:textSize="14dp" />
                <EditText
                    android:id="@+id/etrequestbloodhospitaladdress"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:fontFamily="@font/poppins_semibold"
                    android:hint="Hospital Address"
                    android:textSize="14dp"
                    android:textColorHint="@color/rs_qoute_color"
                    android:textColor="@color/black"
                    tools:ignore="TextFields"/>

                <EditText
                    android:id="@+id/etrequestbloodcpname"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20sp"
                    android:drawablePadding="10dp"
                    android:fontFamily="@font/poppins_semibold"
                    android:hint="Contact Person Name"
                    android:inputType="textPersonName"
                    android:textColor="@color/black"
                    android:textColorHint="@color/rs_qoute_color"
                    android:textSize="14dp"
                    tools:ignore="TextFields"/>

                <EditText
                    android:id="@+id/etrequestbloodcnumber"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:drawablePadding="10dp"
                    android:fontFamily="@font/poppins_semibold"
                    android:hint="Contact Number"
                    android:textColor="@color/black"
                    android:inputType="phone"
                    android:textColorHint="@color/rs_qoute_color"
                    android:textSize="14dp"
                    tools:ignore="TextFields" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <Button
            android:id="@+id/donatebloodBtn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:backgroundTint="@color/rs_buttons_colour"
            android:fontFamily="@font/poppins_bold"
            android:text="Submit Blood Request"
            android:textColor="#FFFFFF"
            android:textColorHint="@color/rs_heading_color"
            android:textSize="16sp"
            android:textStyle="bold" />

    </LinearLayout>

</ScrollView>