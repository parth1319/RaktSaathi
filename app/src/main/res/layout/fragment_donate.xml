<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="18dp"
            app:cardElevation="6dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Donate Blood"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="@color/rs_buttons_colour"
                    android:gravity="center"
                    android:layout_marginBottom="10dp"/>

                <EditText
                    android:id="@+id/etName"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:hint="Full Name"
                    android:background="@drawable/edittext_line"
                    android:padding="10dp"/>

                <EditText
                    android:id="@+id/etPhone"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:hint="Mobile Number"
                    android:background="@drawable/edittext_line"
                    android:layout_marginTop="6dp"
                    android:padding="10dp"/>

                <!-- AGE -->
                <Spinner
                    android:background="@drawable/edittext_line"
                    android:id="@+id/spAge"
                    android:layout_width="match_parent"
                    android:layout_height="45dp"
                    android:layout_marginTop="8dp"
                    />

                <!-- BLOOD -->
                <Spinner
                    android:id="@+id/spBlood"
                    android:layout_width="match_parent"
                    android:layout_height="45dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/edittext_line"
                    />

                <!-- DISTRICT SPINNER -->
                <Spinner
                    android:id="@+id/spArea"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/edittext_line"
                    />

                <!-- ADDRESS INPUT -->
                <EditText
                    android:id="@+id/etAddress"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:hint="Enter Full Address"
                    android:padding="12dp"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/edittext_line"
                    />

                <!-- FINAL ADDRESS SHOW -->
                <TextView
                    android:id="@+id/tvFinalAddress"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Selected Address"
                    android:textStyle="bold"
                    android:textColor="#000"
                    android:padding="12dp"
                    android:background="@drawable/edittext_line"
                    android:layout_marginTop="10dp"/>
                <Button
                    android:id="@+id/btnDonate"
                    android:layout_width="match_parent"
                    android:layout_height="42dp"
                    android:text="BECOME DONOR"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:layout_marginTop="10dp"
                    android:backgroundTint="@color/rs_buttons_colour"/>
            </LinearLayout>
        </LinearLayout>

        <!-- ✅ SUCCESS -->
        <TextView
            android:id="@+id/successMsg"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="✅ Request Sent Successfully"
            android:textColor="#2E7D32"
            android:padding="10dp"
            android:visibility="gone"/>

        <!-- 🔥 REQUEST TITLE -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Blood Requests"
            android:textStyle="bold"
            android:textSize="19sp"
            android:layout_marginTop="10dp"
            android:textColor="#333"/>

        <!-- 🔥 LIST -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerRequests"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:background="@color/white"/>

    </LinearLayout>
</ScrollView>