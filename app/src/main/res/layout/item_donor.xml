<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginBottom="16dp"
    app:cardCornerRadius="28dp"
    app:cardElevation="6dp"
    app:cardBackgroundColor="@color/cardColor">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <!-- PREMIUM BLOOD GROUP BADGE -->
        <RelativeLayout
            android:layout_width="65dp"
            android:layout_height="65dp">

            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_premium_notification"
                android:backgroundTint="#0D000000" />

            <TextView
                android:id="@+id/tvBlood"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="O+"
                android:textColor="#D32F2F"
                android:textStyle="bold"
                android:textSize="22sp"/>
        </RelativeLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="18dp">

            <TextView
                android:id="@+id/tvName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Donor Name"
                android:textColor="@color/textPrimary"
                android:textStyle="bold"
                android:textSize="18sp"
                android:letterSpacing="0.01"/>

            <TextView
                android:id="@+id/tvLocation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="📍 Mumbai, Maharashtra"
                android:textColor="#D32F2F"
                android:textStyle="bold"
                android:textSize="13sp"
                android:layout_marginTop="4dp"
                android:alpha="0.9"/>

            <TextView
                android:id="@+id/tvAddress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Andheri West, Near Station"
                android:textColor="@color/textSecondary"
                android:textSize="13sp"
                android:layout_marginTop="4dp"
                android:maxLines="1"
                android:ellipsize="end"/>
        </LinearLayout>

        <!-- INTERACTIVE CALL BUTTON -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/btnCallContainer"
            android:layout_width="52dp"
            android:layout_height="52dp"
            app:cardCornerRadius="26dp"
            app:cardElevation="4dp"
            app:strokeWidth="0dp"
            app:cardBackgroundColor="#4CAF50"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground">

            <ImageView
                android:id="@+id/btnCall"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@android:drawable/stat_sys_phone_call"
                app:tint="@color/white"
                android:padding="15dp"
                android:scaleType="fitCenter"/>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

</androidx.cardview.widget.CardView>