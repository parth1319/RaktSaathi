<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Base.Theme.RaktSaathi" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/accentColor</item>
        <item name="android:statusBarColor">#7F0000</item>
        <item name="android:windowLayoutInDisplayCutoutMode">never</item>

        <item name="android:colorBackground">@color/bgColor</item>
        <item name="colorSurface">@color/cardColor</item>
        <item name="android:textColorPrimary">@color/textPrimary</item>
        <item name="android:textColorSecondary">@color/textSecondary</item>
    </style>

    <style name="Theme.RaktSaathi" parent="Base.Theme.RaktSaathi"/>

    <!-- Splash Screen Theme -->
    <style name="Theme.App.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#F8F9FA</item>
        <item name="windowSplashScreenAnimatedIcon">@android:color/transparent</item>
        <item name="postSplashScreenTheme">@style/Theme.RaktSaathi</item>
    </style>

    <!-- Premium Bottom Sheet Theme -->
    <style name="BottomSheetDialogTheme" parent="Theme.Design.Light.BottomSheetDialog">
        <item name="bottomSheetStyle">@style/BottomSheetStyle</item>
    </style>

    <style name="BottomSheetStyle" parent="Widget.Design.BottomSheet.Modal">
        <item name="android:background">@android:color/transparent</item>
    </style>

    <style name="App.CustomIndicator" parent="">
        <item name="android:color">@android:color/transparent</item>
    </style>

</resources>